<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WindowsAudioManager.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WindowsAudioManager"
    Title="Windows Audio Manager">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base"/>
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" x:Name="AppTitleBar" Padding="14,6,14,0" Height="36">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Left">
                <FontIcon Glyph="&#xE7F5;" FontSize="14"
                          Foreground="{ThemeResource SystemAccentColor}"/>
                <TextBlock Text="Windows Audio Manager"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1" Spacing="16" Margin="20,24,20,16">

            <Grid Margin="0,0,0,8">
                <TextBlock Text="Windows Audio Manager"
                           Style="{StaticResource TitleTextBlockStyle}"
                           FontFamily="{StaticResource AppFontBold}"
                           VerticalAlignment="Center"/>
                <Button Click="SettingsButton_Click"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE713;" FontSize="14"/>
                        <TextBlock Text="설정"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Equalizer APO"
                               Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="LoudMaxOnButton" Click="LoudMaxOnButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE93E;" FontSize="14"/>
                                <TextBlock Text="LoudMax On"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="LoudMaxOffButton" Click="LoudMaxOffButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE74F;" FontSize="14"/>
                                <TextBlock Text="LoudMax Off"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <TextBlock x:Name="LoudMaxStatusText"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                </StackPanel>
            </Border>

            <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel Spacing="12">
                    <Grid>
                        <TextBlock Text="Windows Audio Settings"
                                   Style="{StaticResource SubtitleTextBlockStyle}"
                                   VerticalAlignment="Center"/>
                        <Button Click="RefreshButton_Click" HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                                <TextBlock Text="새로고침"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="6" Margin="0,0,16,0">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE7F5;" FontSize="14"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="출력 장치"
                                           Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            </StackPanel>
                            <ItemsControl x:Name="OutputList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:AudioDevice">
                                        <Button Click="DeviceButton_Click"
                                                Tag="{x:Bind Id}"
                                                Style="{StaticResource DeviceItemButtonStyle}"
                                                Margin="0,3">
                                            <Grid ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="3"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0"
                                                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                        CornerRadius="1.5"
                                                        Visibility="{x:Bind CheckVisibility}"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{x:Bind Name}"
                                                           VerticalAlignment="Center"/>
                                                <FontIcon Grid.Column="3" Glyph="&#xE73E;"
                                                          FontSize="12"
                                                          Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                                          Visibility="{x:Bind CheckVisibility}"/>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <Border Grid.Column="1" Width="1"
                                Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                                Margin="0,8"/>

                        <StackPanel Grid.Column="2" Spacing="6" Margin="16,0,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE720;" FontSize="14"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="입력 장치"
                                           Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            </StackPanel>
                            <ItemsControl x:Name="InputList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:AudioDevice">
                                        <Button Click="DeviceButton_Click"
                                                Tag="{x:Bind Id}"
                                                Style="{StaticResource DeviceItemButtonStyle}"
                                                Margin="0,3">
                                            <Grid ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="3"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0"
                                                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                        CornerRadius="1.5"
                                                        Visibility="{x:Bind CheckVisibility}"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{x:Bind Name}"
                                                           VerticalAlignment="Center"/>
                                                <FontIcon Grid.Column="3" Glyph="&#xE73E;"
                                                          FontSize="12"
                                                          Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                                          Visibility="{x:Bind CheckVisibility}"/>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>

                    <TextBlock x:Name="StatusText"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>
